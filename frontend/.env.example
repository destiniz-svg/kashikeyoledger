# Frontend build-time configuration (Vite). These are baked into the static
# build, so set them as Railway service variables before the build runs.
# Copy to .env for local `npm run dev`.

# API origin. Leave unset in production to call the API on the same origin
# (the Railway service hosts both the app and the API).
VITE_API_BASE_URL=

# Read-only API key, so the dashboard can load data before the user signs in.
VITE_API_KEY=

# Supabase Auth (email/password sign-in). Use the ANON/publishable key here —
# never the service-role key.
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
