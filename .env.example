# Copy to .env for local dev, or set these as service variables on Railway.
# Leave the Supabase vars unset to run the server on the in-memory backend.

# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Service-role key (SECRET — do not commit). Supabase dashboard:
# Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=

# The organizations.id this service operates on.
KASHIKEYO_ORG_ID=

# API key required for write requests (POST). Also grants read access.
# If unset, all writes are rejected with 503 (fail-closed).
# Generate one with:
#   node -e "console.log('sk_'+require('crypto').randomBytes(24).toString('hex'))"
KASHIKEYO_API_KEY=

# Optional read-only API key. Grants access to GET data endpoints but NOT writes.
# When either key is set, data reads require a valid key; /health stays open.
KASHIKEYO_READ_API_KEY=

# Optional; the host (Railway) sets this. Defaults to 3000.
# PORT=3000
